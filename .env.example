# ============================================================
# QuranVerse AI — API Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/quranverse

# Secret for signing session tokens — must be a long random string (required)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_secret_string_at_least_32_chars

# Port the server listens on (Railway/Render set this automatically)
PORT=3000

# Node environment
NODE_ENV=production

# OpenAI API key for AI Tafseer feature (optional)
# Without this, the AI Tafseer feature will not work
# OPENAI_API_KEY=sk-...
